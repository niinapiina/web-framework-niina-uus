<h1>Movie Collection</h1>

<div class="movie-container">
{{#each movies}}
    <div class="movie-card">
    <h2>{{this.title}}</h2>
    <p><strong>Director:</strong> {{this.director}}</p>
    <p><strong>Release date:</strong> {{this.releaseDate}}</p>
    <p><strong>Genres:</strong> {{this.genres}}</p>
    <p><strong>Rating:</strong> {{this.rating}}</p>
    <p><strong>Watched:</strong> {{this.watched}}</p>
    </div>
{{/each}}
</div>